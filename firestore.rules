rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────
    function isAnyAdmin() {
      return request.auth != null &&
        request.auth.token.admin == true;
    }

    function isTenantStaff(tenantId) {
      return request.auth != null &&
        tenantId != null &&
        request.auth.uid in get(/databases/$(database)/documents/saas_tenants/$(tenantId)).data.staffUids;
    }

    function isValidPhone(phone) {
      return phone.matches('^01[0125][0-9]{8}$');
    }

    // Patient's OTP-verified phone (custom-token claim); null if absent.
    function verifiedPhone() {
      return request.auth != null ? request.auth.token.verified_phone : null;
    }

    // Doctor identity is carried as a custom-token claim (doctor_id),
    // since doctors are not listed in any tenant staffUids array.
    function isDoctorOf(doctorId) {
      return request.auth != null &&
        request.auth.token.doctor_id == doctorId;
    }

    // ─── comm_doctors ────────────────────────────────────────────────────
    match /comm_doctors/{doctorId} {
      allow read: if true;
      allow create: if isAnyAdmin() || isTenantStaff(request.resource.data.tenantId);
      allow update: if isAnyAdmin() || isTenantStaff(resource.data.tenantId) || isDoctorOf(doctorId);
      allow delete: if isAnyAdmin();
    }

    // ─── comm_tenants ────────────────────────────────────────────────────
    match /comm_tenants/{tenantId} {
      allow read: if true;
      allow create: if isAnyAdmin();
      allow update: if isAnyAdmin() || isTenantStaff(tenantId);
      allow delete: if isAnyAdmin();
    }

    // ─── comm_patients ───────────────────────────────────────────────────
    match /comm_patients/{phone} {
      allow read: if isAnyAdmin() ||
        isTenantStaff(resource.data.tenantId) ||
        verifiedPhone() == phone;
      allow create: if isAnyAdmin() ||
        (request.resource.data.phone == phone && isValidPhone(phone)) ||
        verifiedPhone() == phone;
      allow update: if isAnyAdmin() ||
        isTenantStaff(resource.data.tenantId) ||
        verifiedPhone() == phone;
      allow delete: if isAnyAdmin();
    }

    // ─── comm_appointments ───────────────────────────────────────────────
    // SECURITY: CREATE is admin-only to prevent client-controlled
    // routing fields (providerId, licenseKey, doctorId, tenantId).
    // The Community App calls POST /api/community/bookings on Ziara ERP,
    // which validates the doctor and injects trusted routing fields.
    // UPDATE permits patients/staff but enforces immutable routing fields
    // so forged providerId/licenseKey/doctorId cannot be injected post-creation.
    match /comm_appointments/{appointmentId} {
      allow read: if isAnyAdmin() ||
        isTenantStaff(resource.data.tenantId) ||
        verifiedPhone() == resource.data.patientPhone;
      allow create: if isAnyAdmin();
      allow update: if (
        isAnyAdmin() ||
        isTenantStaff(resource.data.tenantId) ||
        verifiedPhone() == resource.data.patientPhone
      )
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.licenseKey == resource.data.licenseKey
        && request.resource.data.doctorId == resource.data.doctorId
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.providerType == resource.data.providerType;
      allow delete: if isAnyAdmin();
    }

    // ─── comm_telegram_links (server-only: pre-booking linkage) ─────────
    match /comm_telegram_links/{phone} {
      allow read, write: if false;
    }

    // ─── comm_otp_requests (server-only: OTP codes) ─────────────────────
    match /comm_otp_requests/{id} {
      allow read, write: if false;
    }

    // ─── comm_doctor_availability (public read, doctor/admin write) ───────
    match /comm_doctor_availability/{doctorId} {
      allow read: if true;
      allow write: if isAnyAdmin() || isDoctorOf(doctorId);
    }

    // ─── comm_doctor_users ───────────────────────────────────────────────
    match /comm_doctor_users/{email} {
      allow read: if request.auth != null &&
        request.auth.token.email == email;
      allow create, update: if isAnyAdmin();
      allow delete: if false;
    }

    // ─── patient_support_requests ────────────────────────────────────────
    match /patient_support_requests/{requestId} {
      allow read: if isAnyAdmin() ||
        (request.auth != null && isTenantStaff(resource.data.tenantId));
      allow create: if request.auth != null;
      allow update: if isAnyAdmin();
      allow delete: if isAnyAdmin();
    }

    // ─── saas_* collections (admin-only) ─────────────────────────────────
    match /saas_tenants/{tenantId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /saas_doctors/{doctorId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /saas_licenses/{licenseId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /saas_settings/{settingId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    // ─── NEW: License System Collections ────────────────────────────────
    match /app_versions/{appId} {
      allow read, write: if isAnyAdmin();
      match /releases/{versionId} {
        allow read, write: if isAnyAdmin();
      }
    }

    match /licenses/{licenseId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /server_license/{docId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /server_instances/{macAddress} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /invalid_reports/{reportId} {
      allow read: if isAnyAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAnyAdmin();
    }

    match /license_logs/{logId} {
      allow read, write: if isAnyAdmin();
    }

    match /servers/{serverId} {
      allow read: if isAnyAdmin();
      allow create, update, delete: if isAnyAdmin();
    }

    match /sync_queue/{queueId} {
      allow read, write: if isAnyAdmin();
    }

    match /saas_audit_events/{eventId} {
      allow read, write: if isAnyAdmin();
    }

    // ─── Procurement Collections (admin-only) ────────────────────────────
    match /suppliers/{supplierId} {
      allow read, write: if isAnyAdmin();
    }

    match /purchase_orders/{poId} {
      allow read, write: if isAnyAdmin();
    }

    match /purchase_order_items/{itemId} {
      allow read, write: if isAnyAdmin();
    }

    match /goods_receipts/{receiptId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update: if isAnyAdmin();
      allow delete: if false;
    }

    match /goods_receipt_items/{itemId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update, delete: if false;
    }

    match /procurement_audit_log/{logId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update, delete: if false;
    }

    match /procurement_meta/{tenantId} {
      allow read, write: if isAnyAdmin();
    }

    // ─── Inventory Collections (admin-only) ──────────────────────────────
    match /inventory_categories/{categoryId} {
      allow read, write: if isAnyAdmin();
    }

    match /inventory_items/{itemId} {
      allow read, write: if isAnyAdmin();
    }

    match /inventory_movements/{movementId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update, delete: if false;
    }

    match /inventory_adjustments/{adjustmentId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update: if isAnyAdmin();
      allow delete: if false;
    }

    match /inventory_stock_counts/{countId} {
      allow read, write: if isAnyAdmin();
    }

    match /inventory_audit_log/{logId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update, delete: if false;
    }

    // ─── Deny everything else by default ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
