# Admin Panel - Environment Variables (SAFE TO COMMIT)
# Copy this file to .env and fill in real values (NEVER commit .env)

# Firebase Client SDK (used by src/firebase.js)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudinary (used by src/lib/cloudinary.js)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Optional API base URL (defaults to "" — same origin)
VITE_API_BASE=

# =============================================================================
# SERVER-SIDE ENV VARS (NOT VITE_ prefix — set in Vercel dashboard, NOT in .env)
# Required by Vercel serverless functions under api/admin/*.js
# =============================================================================
# Base64-encoded Firebase Admin SDK service account JSON (REQUIRED)
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=your_base64_encoded_json_here

# Gmail credentials for sending OTP emails (REQUIRED for registration)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Owner email to receive OTP notifications (REQUIRED for registration)
OWNER_EMAIL=owner@example.com